# Django Settings
# ================================================================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env file to git (it contains sensitive information)
# ================================================================================

# Django Secret Key - Used for sessions, CSRF tokens, etc.
# Generate a new one for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-your-random-secret-key-change-in-production

# Debug Mode - MUST be False in production
# Set to True for development (shows detailed error pages)
DEBUG=True

# Allowed Hosts - Comma-separated list of domains this app can serve
# For development: localhost,127.0.0.1
# For production: example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ================================================================================
# API Keys (Optional but Recommended)
# ================================================================================

# Anthropic Claude API Key (Optional)
# Get it from: https://console.anthropic.com/
# Without this, the app works with local models only
# Format: sk-ant-... (they provide it in console)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ================================================================================
# Database Configuration (Default: SQLite)
# ================================================================================

# For SQLite (default, no changes needed):
# Just leave these commented out or remove them

# For PostgreSQL (uncomment and modify):
# DATABASE_URL=postgresql://username:password@localhost:5432/sarcasm_db

# For MySQL (uncomment and modify):
# DATABASE_URL=mysql://username:password@localhost:3306/sarcasm_db

# ================================================================================
# Static & Media Files
# ================================================================================

# Static files directory (CSS, JS, images served by Django)
STATIC_ROOT=staticfiles/
STATIC_URL=/static/

# Media files directory (User uploads)
MEDIA_URL=/media/
MEDIA_ROOT=media/

# ================================================================================
# Email Configuration (For future use)
# ================================================================================

# Email backend for sending emails (reset password, notifications, etc.)
# For development, use console (prints to terminal)
# For production, use SMTP
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For SMTP (Gmail example):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ================================================================================
# Security Settings (For Production)
# ================================================================================

# HTTPS enforcement (set to True in production)
# SECURE_SSL_REDIRECT=False

# Security headers
# SECURE_BROWSER_XSS_FILTER=True
# SECURE_CONTENT_SECURITY_POLICY=default-src 'self'
# X_FRAME_OPTIONS=DENY

# ================================================================================
# Model & ML Settings
# ================================================================================

# Force CPU mode (leave as default to auto-detect)
# Set to "True" if you want to force CPU despite having GPU
# FORCE_CPU_MODE=False

# Hugging Face cache directory (auto-downloads models here)
# Default: ~/.cache/huggingface/
# HF_HOME=/custom/path/to/cache

# ================================================================================
# Logging (For debugging)
# ================================================================================

# Set to True for verbose logging (development only)
# LOG_LEVEL=DEBUG

# ================================================================================
# Server Configuration
# ================================================================================

# Port (usually 8000 for development)
# PORT=8000

# Gunicorn workers (for production)
# GUNICORN_WORKERS=4

# ================================================================================
# Notes
# ================================================================================

# 1. SECRET_KEY: Generate a strong random key for production
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# 2. DEBUG: Always False in production (shows less error details, faster)

# 3. ALLOWED_HOSTS: Add your domain when deploying to production

# 4. ANTHROPIC_API_KEY: Optional but recommended for enhanced reasoning
#    Get it free from: https://console.anthropic.com/

# 5. For deployment to Heroku/Railway/PythonAnywhere:
#    - Copy these values to their config var / environment variable settings
#    - Keep .env file in .gitignore (don't commit secrets!)

# ================================================================================
